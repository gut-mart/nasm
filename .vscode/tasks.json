{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Construir Proyecto Actual",
            "type": "shell",
            "command": "make clean && make SRC=${relativeFile}",
       
             "group": {
                "kind": "build",
                "isDefault": true
