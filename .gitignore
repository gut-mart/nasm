# ==============================================================================
# .gitignore - Archivos ignorados por Git
# ==============================================================================

# Directorios de build y binarios
build/
bin/
dist/
*.out
*.elf

# Archivos objeto y dependencias
*.o
*.d
*.a

# VS Code
.vscode/settings.json
.vscode/launch.json
.vscode/.history/

# IDE y editores
.idea/
*.swp
*.swo
*~
.DS_Store

# Archivos temporales y logs
*.tmp
*.temp
*.log
debug.txt
.cache/

# Makefiles autogenerados en carpetas de comandos
comandos/**/Makefile

# Depuración
.gdbhistory
core
vgcore.*

# Tests y resultados
.test_output/
test_results.txt

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# Información de proyecto local
revision.txt
contexto_IA.txt
