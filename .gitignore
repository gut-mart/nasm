# ==============================================================================
# .gitignore - Archivos ignorados por Git
# ==============================================================================

# --- Directorios de build y binarios ---
build/
bin/
dist/
*.out
*.elf

# --- Archivos objeto y dependencias ---
*.o
*.d
*.a

# --- VS Code: solo archivos personales del desarrollador ---
# settings.json, launch.json, tasks.json y extensions.json se versionan.
# launch.json no contiene datos personales (la IP remota se lee de la
# variable de entorno NASM_REMOTE_HOST). Solo se ignora la carpeta de
# historial de cambios local.
.vscode/.history/

# --- IDE y editores ---
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Archivos temporales y logs ---
*.tmp
*.temp
*.log
debug.txt
.cache/

# --- Configuración local del usuario ---
# Cada desarrollador define aquí su IP de despliegue, alias SSH, etc.
# Ver config.example.mk como plantilla.
config.local.mk

# --- Makefiles autogenerados en carpetas de comandos ---
# Son derivados del .asm correspondiente. Los regenera setup.sh durante
# la instalación (vía bootstrap de monitor_comandos.sh) y monitor_comandos.sh
# los mantiene actualizados si se ejecuta como watcher.
comandos/**/Makefile

# --- Depuración ---
.gdbhistory
/core
vgcore.*

# --- Tests y resultados ---
.test_output/
test_results.txt

# --- Python ---
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# --- Información de proyecto local ---
# Reportes generados para revisiones (empaquetar.sh) o para enviar a IA.
revision.txt
contexto_IA.txt
# --- Scripts del mantenedor ---
# Carpeta personal del mantenedor: scripts y herramientas que no aportan
# valor a usuarios del repo y suelen contener rutas/configuraciones
# personales. Ver scripts/maintainer/README.md (local) si la carpeta existe.
scripts/maintainer/
